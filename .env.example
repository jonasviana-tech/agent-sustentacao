# sustentacao-agent — copie para .env e preencha os valores
# O arquivo .env NUNCA sobe ao Git (está no .gitignore)

# ---- LLM ----
# Provedor: anthropic | openai | gemini | mock
LLM_PROVIDER=gemini

# Gemini
GEMINI_API_KEY=
LLM_MODEL=gemini-2.0-flash

# Anthropic (se LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-sonnet-4-20250514

# OpenAI (se LLM_PROVIDER=openai)
# OPENAI_API_KEY=
# LLM_MODEL=gpt-4o-mini

# ---- Autenticação ----
# Mesmo valor configurado no Freshdesk Automator (header X-Webhook-Secret)
WEBHOOK_SHARED_SECRET=

# Chave para o endpoint on-demand POST /v1/triagem (header X-API-Key)
API_KEY=

# ---- Freshdesk ----
FRESHDESK_DOMAIN=tech4humans.freshdesk.com

# ---- Serviço ----
# Render injeta PORT automaticamente; não altere em produção
PORT=3000

# ---- Caminhos (opcional — defaults já funcionam) ----
# Pasta dos arquivos .md da base de conhecimento (default: ./docs)
# DOCS_ROOT=./docs

# Arquivo de mapeamento cliente/projeto/responsável (default: ./config/clientes.json)
# CLIENTES_PATH=./config/clientes.json
